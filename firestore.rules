
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isRole(role) {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isSenior() {
      return isRole('senior');
    }

    function isJunior() {
      return isRole('junior');
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Collection rules
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(userId); // Allow users to create their own doc
      allow update: if (isSenior() || (isJunior() && isOwner(userId) && !('role' in request.resource.data)));
      // Note: Deleting users should be handled by a Cloud Function for atomicity (deleting from Auth and Firestore)
      allow delete: if isSenior();
    }

    match /settings/{docId} {
       allow read: if isAuth();
       allow write: if isSenior();
    }
    
    match /products/{productId} {
      allow read: if isAuth();
      allow write: if isSenior();
    }
    
    match /containers/{containerId} {
      allow read: if isAuth();
      allow write: if isSenior();
    }
    
    match /history/{historyId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // History should be immutable
    }
  }
}
