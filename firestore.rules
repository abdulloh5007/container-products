rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read for products
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow authenticated read/write for containers and history
    match /containers/{containerId} {
      allow read, write: if request.auth != null;
    }
    
    match /history/{historyId} {
        allow read, write: if request.auth != null;
    }

    // Allow users to be listed by anyone (for registration check),
    // but only allow a user to read/write their own document.
    match /users/{userId} {
      allow list: if true;
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read/write settings
    match /settings/{settingId} {
        allow read, write: if request.auth != null;
    }
  }
}
