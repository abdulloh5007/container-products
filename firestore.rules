rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Security: Deny all access unless specified below ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Public Access Rules ---
    // Anyone can read product information for the public-facing pages.
    match /products/{productId} {
      allow read: if true;
      // Only authenticated users can modify products (from the admin panel).
      allow write: if request.auth != null;
    }
    
    // --- Authenticated User Rules ---
    // An authenticated user can manage their OWN user document completely.
    // This allows them to update their profile, add sessions on login,
    // and remove sessions on logout. This is the key rule that fixes the permission errors.
    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      // Anyone can check if users exist (for registration purposes).
      allow list: if true;
      // An authenticated user can create their own user document during registration.
      allow create: if request.auth.uid == userId;
    }

    // Only authenticated users can access these collections from the admin panel.
    match /containers/{containerId} {
        allow read, write: if request.auth != null;
    }
    
    match /history/{historyId} {
        allow read, write: if request.auth != null;
    }

    // Only authenticated users can manage global settings.
    match /settings/global {
      allow read, write: if request.auth != null;
    }
  }
}
