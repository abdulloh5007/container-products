
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSenior() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'senior';
    }

    function isJunior() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'junior';
    }

    function isAuthenticated() {
        return request.auth != null;
    }

    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isSenior();
      allow delete: if isSenior();
    }
    
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if isSenior() || request.auth.uid == resource.data.userId;
      allow delete: if isSenior();
    }
    
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isSenior();
    }

    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSenior();
    }
  }
}
