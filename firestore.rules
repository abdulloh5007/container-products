
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Products Collection ---
    // Anyone can read the products list.
    // Only authenticated users (admins) can create, update, or delete products.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- Containers Collection ---
    // Only authenticated users (admins) can read or write containers.
    match /containers/{containerId} {
      allow read, write: if isAuthenticated();
    }

    // --- History Collection ---
    // Only authenticated users can read history.
    // Only authenticated users can create history records.
    // Updating or deleting history is disallowed to maintain audit trail integrity.
    match /history/{historyId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // --- Users Collection ---
    // Users can read and update their own document.
    // This is necessary for session management and profile updates.
    match /users/{userId} {
       allow read, update: if isAuthenticated() && request.auth.uid == userId;
       // Allow creation only if the user is creating their own document.
       allow create: if isAuthenticated() && request.auth.uid == userId;
       // Disallow deletion for now to prevent users from deleting their own accounts via direct API call.
       // Deletion logic is handled server-side/in secure functions.
       allow delete: if false;
    }
    
    // --- Settings Collection ---
    // Only authenticated users can read and write global settings.
    // This allows senior admins to toggle management mode.
    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }
  }
}
