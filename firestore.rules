rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read for products
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to manage containers and history
    match /containers/{containerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /history/{historyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Rules for stock modification history
    match /stock_history/{historyId} {
      allow create: if request.auth != null;
      allow read, list, update, delete: if request.auth != null;
    }

    // Users can list the collection to check if any users exist.
    // However, they can only read/write their own document.
    match /users/{userId} {
      allow list: if true;
      allow read, write: if true;
    }
    
    // Settings can be read/written by any authenticated user
    match /settings/global {
      allow read, write: if true;
    }

    // Allow authenticated users to manage rentals
    match /rentals/{rentalId} {
      allow read, write: if request.auth != null;
    }
  }
}
