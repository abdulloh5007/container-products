rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.userRole;
    }

    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is a specific role
    function isRole(role) {
      return isSignedIn() && getUserRole(request.auth.uid) == role;
    }

    // Helper function to check if the user is one of multiple roles
    function isOneOfRoles(roles) {
      return isSignedIn() && getUserRole(request.auth.uid) in roles;
    }

    // Users collection
    // senior: Can manage all users.
    // users: Can update their own data.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isRole('senior'); // New users are created via QR tokens or senior registration
      allow update: if isRole('senior') || request.auth.uid == userId;
      allow delete: if isRole('senior');
    }
    
    // Products collection
    // Read: Publicly readable for the home page.
    // Write: senior, junior, worker can update stock.
    match /products/{productId} {
      allow read: if true;
      allow write: if isOneOfRoles(['senior', 'junior', 'worker']);
    }
    
    // Containers collection
    // Only senior and junior can create/manage containers.
    match /containers/{containerId} {
        allow read, write: if isOneOfRoles(['senior', 'junior']);
    }

    // History of acceptance/dispatch operations
    // Only senior and junior perform these operations.
    match /history/{historyId} {
        allow read, write: if isOneOfRoles(['senior', 'junior']);
    }
    
    // History of manual stock changes
    // senior, junior, and worker can all adjust stock.
    match /stock_history/{historyId} {
      allow read, write: if isOneOfRoles(['senior', 'junior', 'worker']);
    }
    
    // Rentals collection
    // senior, junior, and worker can all manage rentals.
    match /rentals/{rentalId} {
       allow read, write: if isOneOfRoles(['senior', 'junior', 'worker']);
    }

    // QR Login Tokens
    // Create: Only senior can generate tokens.
    // Read/Update: Anyone (unauthenticated) can use a token once to log in.
    match /qr_login_tokens/{tokenId} {
      allow create: if isRole('senior');
      allow read, update: if !resource.data.used; // Allow using a token only if it's not used yet
    }
    
    // Settings collection (for senior user profile)
    // Only senior can read/write settings.
    match /settings/{settingId} {
        allow read, write: if isRole('senior');
    }
  }
}
