
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isSenior() {
      return isAuthenticated() && isRole('senior');
    }

    function isJunior() {
      return isAuthenticated() && isRole('junior');
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Global settings
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isSenior();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isSenior() || isOwner(userId));
      allow create: if isOwner(userId); // Allow user to create their own doc
      allow update: if isAuthenticated() && (isSenior() || (isOwner(userId) && !('role' in request.resource.data))); // Junior can update profile, but not their role
      allow delete: if isSenior();
    }

    // Products and Containers can be read by any authenticated user, but only managed by seniors
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isSenior(); // create, update, delete
    }

    match /containers/{containerId} {
      allow read: if isAuthenticated();
      allow write: if isSenior(); // create, update, delete
    }

    // History can be read and created by any authenticated user
    match /history/{historyId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false; // History should be immutable
    }
  }
}
