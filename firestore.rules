
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSenior(userId) {
      let sessions = get(/databases/$(database)/documents/users/$(userId)).data.sessions;
      let currentSessionId = request.auth.token.sessionId;
      let currentSession = sessions.filter(s => s.id == currentSessionId)[0];
      return currentSession.role == 'senior';
    }
    
    function isJunior(userId) {
       let sessions = get(/databases/$(database)/documents/users/$(userId)).data.sessions;
       let currentSessionId = request.auth.token.sessionId;
       let currentSession = sessions.filter(s => s.id == currentSessionId)[0];
       return currentSession.role == 'junior';
    }

    function isAuthenticated(userId) {
        return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated(userId);
      allow create: if request.auth.uid == userId;
      
      allow update: if isAuthenticated(userId) && (
        // Senior can update anything
        isSenior(userId) ||
        // A user can update their own name/phone
        (request.resource.data.keys().hasOnly(['name', 'phone', 'sessions', 'uid', 'email']))
      );
    }
    
    match /settings/global {
        allow read: if request.auth != null;
        allow write: if isSenior(request.auth.uid);
    }

    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if isSenior(request.auth.uid) && get(/databases/$(database)/documents/settings/global).data.isManagementModeEnabled == true;
    }

    match /containers/{containerId} {
      allow read: if request.auth != null;
      allow write: if isSenior(request.auth.uid) && get(/databases/$(database)/documents/settings/global).data.isManagementModeEnabled == true;
    }

    match /history/{historyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // History is immutable
    }
    
     match /sessions/{sessionId} {
      allow read, write: if false; // This collection is not used in the new model
    }
  }
}

    