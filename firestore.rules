rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admins to read/write products and containers
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }
    match /containers/{containerId} {
      allow read, write: if request.auth != null;
    }
    // Allow users to manage their own profile information
    match /users/{userId} {
      // User can read and update their own document.
      // The userId is the phone number, which we extract from the auth token's email.
      allow read, update: if request.auth != null && request.auth.token.email.split('@')[0] == userId;
      // User can create their own document, but only if the phone number matches.
      allow create: if request.auth != null && request.auth.token.email.split('@')[0] == request.resource.data.phone;
    }
  }
}
